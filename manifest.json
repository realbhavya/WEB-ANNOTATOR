{
  "manifest_version": 3,
  "name": "WebAnnotator",
  "version": "1.0.0",
  "description": "Highlight text, write sticky notes, and draw shapes on any webpage. Annotations persist across sessions.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/utils.js",
        "content/storage.js",
        "content/highlights.js",
        "content/notes.js",
        "content/shapes.js",
        "content/context-menu.js",
        "content/toolbar.js",
        "content/main.js"
      ],
      "css": ["content/styles.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
